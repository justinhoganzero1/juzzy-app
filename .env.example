# Stripe
STRIPE_SECRET_KEY=sk_test_...
# Create a weekly recurring price in Stripe and put its ID here (price_...)
STRIPE_PRICE_ID_WEEKLY=price_...

# Where Stripe should redirect after checkout
STRIPE_SUCCESS_URL=https://your-app-name.railway.app/?stripe=success
STRIPE_CANCEL_URL=https://your-app-name.railway.app/?stripe=cancel

# Server port (Railway sets PORT automatically)
PORT=5173
